# Database
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=your-api-key"

# Upstash Redis
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# Resend
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="noreply@homecookhub.com"

# NextAuth（生产必须：https 公网根 URL，无尾斜杠，与浏览器完全一致）
NEXTAUTH_URL="http://localhost:3000"
# （生产示例）Railway：https://YOUR_SERVICE.up.railway.app
# GitHub OAuth App → Authorization callback URL：
#   https://YOUR_DOMAIN/api/auth/callback/github
# Google Cloud → OAuth Web 客户端 → 已授权重定向 URI：
#   https://YOUR_DOMAIN/api/auth/callback/google
NEXTAUTH_SECRET="your-super-secret-key-min-32-characters-long"

# GitHub OAuth
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
